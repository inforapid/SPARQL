# Query 1: Strukturaufbau (Verbindungen zwischen Sonne, Planeten und Monden)
SELECT 
  ?i_item1 ?i_item1Label ?i_item1Description
  ?rn_prop1Label (?rn_prop1Label as ?rc_prop1Label) 
  ?i_item2 ?i_item2Label ?i_item2Description
WHERE {
  VALUES (?i_item1 ?i_item2) {
    (wd:Q525 wd:Q2) (wd:Q525 wd:Q111) (wd:Q525 wd:Q193) (wd:Q525 wd:Q308) 
    (wd:Q525 wd:Q313) (wd:Q525 wd:Q319) (wd:Q525 wd:Q324)
    (wd:Q2 wd:Q405) (wd:Q319 wd:Q3123) (wd:Q319 wd:Q3134) 
    (wd:Q319 wd:Q3143) (wd:Q319 wd:Q3169) (wd:Q193 wd:Q2565) (wd:Q193 wd:Q3303)
  }
  OPTIONAL { ?i_item1 wdt:P398 ?i_item2. ?rn_prop1 wikibase:directClaim wdt:P398. }
  SERVICE wikibase:label { bd:serviceParam wikibase:language "en,de". }
}

#query
# Query 2: Anreicherung mit Werten (Robustes Multi-Value Handling via UNION)
SELECT 
  ?i_item ?i_itemLabel ?i_itemDescription ?ii_item ?iu_item
  ?rn_t_Label (?rn_t_Label as ?rc_Label) ?ic_Value
WHERE {
  # Alle beteiligten IDs
  VALUES ?i_item {
    wd:Q525 wd:Q2 wd:Q111 wd:Q193 wd:Q308 wd:Q313 wd:Q319 wd:Q324
    wd:Q405 wd:Q3123 wd:Q3134 wd:Q3143 wd:Q3169 wd:Q2565 wd:Q3303
  }
  
  {
    # 1. Temperatur (P2076)
    ?i_item p:P2076 ?stat. 
    ?stat psv:P2076 [wikibase:quantityAmount ?amt; wikibase:quantityUnit [rdfs:label ?unit]].
    OPTIONAL { ?stat (pq:P518|pq:P1480) [rdfs:label ?qual]. FILTER(LANG(?qual)="en") }
    ?prop wikibase:directClaim wdt:P2076. ?prop rdfs:label ?pLabel. FILTER(LANG(?pLabel)="en")
    BIND(IF(BOUND(?qual), CONCAT(?pLabel, " (", ?qual, ")"), ?pLabel) AS ?rn_t_Label)
  } UNION {
    # 2. Masse (P2067)
    ?i_item p:P2067 ?stat. 
    ?stat psv:P2067 [wikibase:quantityAmount ?amt; wikibase:quantityUnit [rdfs:label ?unit]].
    OPTIONAL { ?stat (pq:P518|pq:P1480) [rdfs:label ?qual]. FILTER(LANG(?qual)="en") }
    ?prop wikibase:directClaim wdt:P2067. ?prop rdfs:label ?pLabel. FILTER(LANG(?pLabel)="en")
    BIND(IF(BOUND(?qual), CONCAT(?pLabel, " (", ?qual, ")"), ?pLabel) AS ?rn_t_Label)
  } UNION {
    # 3. Radius (P2120)
    ?i_item p:P2120 ?stat. 
    ?stat psv:P2120 [wikibase:quantityAmount ?amt; wikibase:quantityUnit [rdfs:label ?unit]].
    OPTIONAL { ?stat (pq:P518|pq:P1480) [rdfs:label ?qual]. FILTER(LANG(?qual)="en") }
    ?prop wikibase:directClaim wdt:P2120. ?prop rdfs:label ?pLabel. FILTER(LANG(?pLabel)="en")
    BIND(IF(BOUND(?qual), CONCAT(?pLabel, " (", ?qual, ")"), ?pLabel) AS ?rn_t_Label)
  } UNION {
    # 4. Rotationsperiode (P2146)
    ?i_item p:P2146 ?stat. 
    ?stat psv:P2146 [wikibase:quantityAmount ?amt; wikibase:quantityUnit [rdfs:label ?unit]].
    OPTIONAL { ?stat (pq:P518|pq:P1480) [rdfs:label ?qual]. FILTER(LANG(?qual)="en") }
    ?prop wikibase:directClaim wdt:P2146. ?prop rdfs:label ?pLabel. FILTER(LANG(?pLabel)="en")
    BIND(IF(BOUND(?qual), CONCAT(?pLabel, " (", ?qual, ")"), ?pLabel) AS ?rn_t_Label)
  } UNION {
    # 5. Durchmesser (P2386)
    ?i_item p:P2386 ?stat. 
    ?stat psv:P2386 [wikibase:quantityAmount ?amt; wikibase:quantityUnit [rdfs:label ?unit]].
    OPTIONAL { ?stat (pq:P518|pq:P1480) [rdfs:label ?qual]. FILTER(LANG(?qual)="en") }
    ?prop wikibase:directClaim wdt:P2386. ?prop rdfs:label ?pLabel. FILTER(LANG(?pLabel)="en")
    BIND(IF(BOUND(?qual), CONCAT(?pLabel, " (", ?qual, ")"), ?pLabel) AS ?rn_t_Label)
  } UNION {
    # 6. Dichte (P2054)
    ?i_item p:P2054 ?stat. 
    ?stat psv:P2054 [wikibase:quantityAmount ?amt; wikibase:quantityUnit [rdfs:label ?unit]].
    OPTIONAL { ?stat (pq:P518|pq:P1480) [rdfs:label ?qual]. FILTER(LANG(?qual)="en") }
    ?prop wikibase:directClaim wdt:P2054. ?prop rdfs:label ?pLabel. FILTER(LANG(?pLabel)="en")
    BIND(IF(BOUND(?qual), CONCAT(?pLabel, " (", ?qual, ")"), ?pLabel) AS ?rn_t_Label)
  } UNION {
    # 7. Fläche (P2046)
    ?i_item p:P2046 ?stat. 
    ?stat psv:P2046 [wikibase:quantityAmount ?amt; wikibase:quantityUnit [rdfs:label ?unit]].
    OPTIONAL { ?stat (pq:P518|pq:P1480) [rdfs:label ?qual]. FILTER(LANG(?qual)="en") }
    ?prop wikibase:directClaim wdt:P2046. ?prop rdfs:label ?pLabel. FILTER(LANG(?pLabel)="en")
    BIND(IF(BOUND(?qual), CONCAT(?pLabel, " (", ?qual, ")"), ?pLabel) AS ?rn_t_Label)
  } UNION {
    # 8. Volumen (P2234)
    ?i_item p:P2234 ?stat. 
    ?stat psv:P2234 [wikibase:quantityAmount ?amt; wikibase:quantityUnit [rdfs:label ?unit]].
    OPTIONAL { ?stat (pq:P518|pq:P1480) [rdfs:label ?qual]. FILTER(LANG(?qual)="en") }
    ?prop wikibase:directClaim wdt:P2234. ?prop rdfs:label ?pLabel. FILTER(LANG(?pLabel)="en")
    BIND(IF(BOUND(?qual), CONCAT(?pLabel, " (", ?qual, ")"), ?pLabel) AS ?rn_t_Label)
  } UNION {
    # 9. Entfernung Erde (P2582)
    ?i_item p:P2582 ?stat. 
    ?stat psv:P2582 [wikibase:quantityAmount ?amt; wikibase:quantityUnit [rdfs:label ?unit]].
    OPTIONAL { ?stat (pq:P518|pq:P1480) [rdfs:label ?qual]. FILTER(LANG(?qual)="en") }
    ?prop wikibase:directClaim wdt:P2582. ?prop rdfs:label ?pLabel. FILTER(LANG(?pLabel)="en")
    BIND(IF(BOUND(?qual), CONCAT(?pLabel, " (", ?qual, ")"), ?pLabel) AS ?rn_t_Label)
  }

  FILTER(LANG(?unit)="en")
  BIND(CONCAT(STR(?amt), " ", ?unit) AS ?ic_Value)

  # Metadaten (Bilder/Links - einmal pro i_item)
  OPTIONAL { ?i_item wdt:P18 ?ii_item. }
  OPTIONAL { ?iu_item schema:about ?i_item; schema:isPartOf <https://en.wikipedia.org/>. }

  SERVICE wikibase:label { bd:serviceParam wikibase:language "en,de". }
}
