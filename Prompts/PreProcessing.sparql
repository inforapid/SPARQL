SELECT DISTINCT ?subjektLabel ?propertyLabel ?objektLabel ?subjekt ?property ?objekt WHERE {
  
  # Definition of the subject object pairs
  VALUES (?subjektName ?objektName) {
    # Planets orbiting the Sun
    ("Sun"@en "Mercury"@en)
    ("Sun"@en "Venus"@en)
    ("Sun"@en "Earth"@en)
    ("Sun"@en "Mars"@en)
    ("Sun"@en "Jupiter"@en)
    ("Sun"@en "Saturn"@en)
    ("Sun"@en "Uranus"@en)
    ("Sun"@en "Neptun"@en)
    
    # Important Moons and their parent planets
    ("Earth"@en "Moon"@en)
    ("Jupiter"@en "Io"@en)
    ("Jupiter"@en "Europa"@en)
    ("Jupiter"@en "Ganymede"@en)
    ("Jupiter"@en "Callisto"@en)
    ("Saturn"@en "Titan"@en)
    ("Saturn"@en "Enceladus"@en)
    ("Neptun"@en "Triton"@en)
  }

  # Step 1: Find the Q-number for the subject via its English label
  ?subjekt rdfs:label ?subjektName.
  FILTER(STRSTARTS(STR(?subjekt), "http://www.wikidata.org/entity/Q"))

  # Step 2: Find the Q-number for the object via its English label
  ?objekt_item rdfs:label ?objektName.
  FILTER(STRSTARTS(STR(?objekt_item), "http://www.wikidata.org/entity/Q"))

  # Type check: Must be an astronomical object (Q6999)
  # This prevents getting movies, bands, or persons with the same name
  FILTER EXISTS { ?subjekt wdt:P31/wdt:P279* wd:Q6999 . }
  FILTER EXISTS { ?objekt_item wdt:P31/wdt:P279* wd:Q6999 . }  

  {
    # Step 3: Check for relationships in both directions
    # (Some are stored as "Sun -> has satellite -> Earth", others as "Moon -> orbits -> Earth")
    ?subjekt ?p ?objekt_item.
    
    # Link the property ID to its direct claim
    ?property wikibase:directClaim ?p.
    BIND(?objekt_item AS ?objekt)
  }
  UNION
  {
    # WAY B: Automatic physical facts for all subjects
    # Define which facts you want to include by default
    VALUES (?physProp ?pProp ?psvProp) {
      (wdt:P2386 p:P2386 psv:P2386) # Durchmesser
      (wdt:P2067 p:P2067 psv:P2067) # Masse
      (wdt:P2076 p:P2076 psv:P2076) # Temperatur
      (wdt:P2120 p:P2120 psv:P2120) # Radius
      (wdt:P2046 p:P2046 psv:P2046) # Fläche
      (wdt:P2234 p:P2234 psv:P2234) # Volumen
      (wdt:P2054 p:P2054 psv:P2054) # Dichte
      (wdt:P2233 p:P2233 psv:P2233) # große Halbachse
      (wdt:P1096 p:P1096 psv:P1096) # Exzentrizität
      (wdt:P2146 p:P2146 psv:P2146) # Rotationsperiode
      (wdt:P2583 p:P2583 psv:P2583) # Entfernung
      (wdt:P4501 p:P4501 psv:P4501) # Albedo
    }

    # Wert-Struktur abrufen
    ?subjekt ?pProp ?statement.
    ?statement ?psvProp ?valueNode.
    
    ?valueNode wikibase:quantityAmount ?amount.
    ?valueNode wikibase:quantityUnit ?unit.
    
    # Label der Einheit (falls vorhanden, sonst leer)
    OPTIONAL { 
      ?unit rdfs:label ?unitLabel. 
      FILTER(LANG(?unitLabel) = "en") 
    }

    # Ergebnisse binden
    BIND(CONCAT(STR(?amount), " ", REPLACE(STR(COALESCE(?unitLabel, "")), "http://www.wikidata.org/entity/", "")) AS ?objektLabel)
    BIND(?physProp AS ?property)
    BIND(?unit AS ?objekt)
  }

  # Label service for readable names in the results
  SERVICE wikibase:label { bd:serviceParam wikibase:language "en,de". }
}
ORDER BY ?subjektLabel